      "seed": 1825102085,
      "version": 3205,
      "versionNonce": 1239290780,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774564394136,
      "link": null,
      "locked": false,
      "text": "The data reveals a dynamic journey of\nMonthly Recurring Revenue (MRR) over\nthe past few years. Starting from\nDecember 2023, MRR was\n**$1,304,103**, and it showed a general\nupward trend through 2024, peaking at\n**$1,872,271** in May 2025. This\nperiod was marked by significant growth,\nparticularly from March 2024's\n**$1,310,142** to November 2025's\n**$1,",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
