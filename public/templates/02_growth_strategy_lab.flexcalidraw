    {
      "id": "nLw8q1DGgUpmU93HJVrsi",
      "type": "text",
      "x": 510.5114696341227,
      "y": 465.02023587907433,
      "width": 320,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
