    {
      "id": "SuTcXwlqr8nwh6F5PWba2",
      "type": "text",
      "x": 878.9813684732586,
      "y": 315.99532588858756,
      "width": 300,
      "height": 540,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "h8Sdd9eUdkjAIN2ftzeWb",
      "index": "aD",
      "roundness": null,
      "seed": 1122652060,
      "version": 3192,
      "versionNonce": 1061314,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774565281936,
      "link": null,
      "locked": false,
      "text": "The data reveals a clear hierarchy in\nthe number of tasks completed across\ndifferent plans. The Free plan leads\nwith a substantial **2,751,586 tasks\ncompleted**, indicating a high level of\nengagement or user base. Following\nthis, the Business plan shows a\nsignificant number of tasks completed\nat **2,686,734**, closely trailing the\nFree plan. This suggests that the\nBusiness plan is also highly utilized,\npossibly reflecting its value\nproposition to users who require more\nfeatures than the Free plan offers.\nThe Enterprise plan, however, has\ncompleted **1,277,924 tasks**, which\nis notably lower than the other two\nplans. This could imply a more niche or\nspecialized user base, potentially\nfocusing on quality over quantity or\nhaving fewer users but with more\ncomplex needs. Overall, the data\nhighlights the Free plan's dominance in\ntask completion, with the Business\nplan not far behind, while the\nEnterprise plan caters to a different\nsegment with fewer tasks completed.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The data reveals a clear hierarchy in the number of tasks completed across different plans. The Free plan leads with a substantial **2,751,586 tasks completed**, indicating a high level of engagement or user base. Following this, the Business plan shows a significant number of tasks completed at **2,686,734**, closely trailing the Free plan. This suggests that the Business plan is also highly utilized, possibly reflecting its value proposition to users who require more features than the Free plan offers. The Enterprise plan, however, has completed **1,277,924 tasks**, which is notably lower than the other two plans. This could imply a more niche or specialized user base, potentially focusing on quality over quantity or having fewer users but with more complex needs. Overall, the data highlights the Free plan's dominance in task completion, with the Business plan not far behind, while the Enterprise plan caters to a different segment with fewer tasks completed.",
      "autoResize": false,
      "lineHeight": 1.25
    },
