    {
      "id": "o7Uw4tKrgs24P6dLBRwhH",
      "type": "text",
      "x": 490.21880139906625,
      "y": 582.0169783749883,
      "width": 380,
      "height": 220,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
